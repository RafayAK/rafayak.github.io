<style>
  .logo-svg {
    transform-origin: center;
    /* Smooth 180 degree rotation on hover with spring-like cubic bezier */
    transition: transform 0.9s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .logo-svg:hover {
    transform: rotate(180deg);
  }

  .logo-path {
    stroke: currentColor;
    stroke-width: 6px;
    stroke-dasharray: 2500;
    stroke-dashoffset: 2500;
    fill-opacity: 0;
    /* Drawing duration is 1.6s */
    animation: drawAndFill 1.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  /* Stagger writing effect from left to right */
  .path-r {
    animation-delay: 0.1s;
  }
  .path-a1 {
    animation-delay: 0.35s;
  }
  .path-f {
    animation-delay: 0.6s;
  }
  .path-a2 {
    animation-delay: 0.85s;
  }
  .path-y {
    animation-delay: 1.1s;
  }

  @keyframes drawAndFill {
    0% {
      stroke-dashoffset: 2500;
      fill-opacity: 0;
      stroke-width: 6px;
    }
    75% {
      stroke-dashoffset: 0;
      fill-opacity: 0;
      stroke-width: 6px;
    }
    90% {
      stroke-dashoffset: 0;
      fill-opacity: 1;
      stroke-width: 3px;
    }
    100% {
      stroke-dashoffset: 0;
      fill-opacity: 1;
      stroke-width: 0px;
    }
  }

  /* Support prefers-reduced-motion: disable writing animations and hover rotations */
  @media (prefers-reduced-motion: reduce) {
    .logo-path {
      stroke-dashoffset: 0;
      fill-opacity: 1;
      stroke-width: 0px;
      animation: none;
    }
    .logo-svg {
      transition: none;
    }
    .logo-svg:hover {
      transform: none;
    }
  }
</style>
