---
/**
 * SquigglyDivider — a hand-drawn wave that draws itself when scrolled into view.
 * After the Astro blog template's animated horizontal rules. Pure SVG + CSS
 * (see `.squiggle` in global.css); a global IntersectionObserver in BaseLayout
 * adds `.in-view` to trigger the draw. Mapped to `<hr>` / `---` inside MDX.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;

// Sine-ish path: one Q seed, then smooth T reflections across a 1200-wide box.
const ts = Array.from({ length: 19 }, (_, i) => `T${(i + 2) * 60} 20`).join(' ');
const d = `M0 20 Q30 6 60 20 ${ts}`;
---

<div
  class={`squiggle my-12 flex justify-center ${className}`}
  role="separator"
  aria-orientation="horizontal"
  data-animate
>
  <svg
    class="w-full max-w-[420px]"
    height="32"
    viewBox="0 0 1200 40"
    preserveAspectRatio="none"
    fill="none"
    aria-hidden="true"
    style="--len: 1600"
  >
    <path
      d={d}
      stroke="var(--pencil)"
      stroke-width="5.5"
      stroke-linecap="round"
    />
  </svg>
</div>
