---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SquigglyDivider from '../../components/SquigglyDivider.astro';
import { href, formatDate } from '../../lib/utils';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Blog — Rafay" description="Writing on AI engineering, evals, and shipping ML.">
  <section class="py-16">
    <h1 class="text-display font-normal leading-tight text-ink">Blog</h1>
    <p class="mt-4 max-w-[48ch] text-subheading text-muted">
      Writing on ML from first principles — the math, the code, the things
      papers never explain ... and, of course, a few ramblings.
    </p>
  </section>

  <SquigglyDivider />

  <ul class="flex flex-col gap-2 py-4">
    {
      posts.map((post) => (
        <li>
          <a
            href={href(`/blog/${post.id}`)}
            class="block rounded-[--radius-card] border border-transparent p-5 text-ink no-underline transition-colors hover:border-border hover:bg-surface"
          >
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="text-heading-sm font-medium">{post.data.title}</h2>
              <time class="shrink-0 text-caption text-muted">
                {formatDate(post.data.pubDate)}
              </time>
            </div>
            <p class="mt-2 text-body text-muted">{post.data.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
